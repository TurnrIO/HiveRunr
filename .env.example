# ── Core ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hiverunr:hiverunr@db:5432/hiverunr
REDIS_URL=redis://redis:6379/0

# Credential encryption key (Fernet / AES-128-CBC + HMAC-SHA256).
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if this is not set, credentials are stored with a weak fallback key.
# WARNING: changing this key after saving credentials will make them unreadable — back up first.
SECRET_KEY=

# API_KEY gates all inbound /webhook/* endpoints.
# Admin access is via the setup/login flow — no ADMIN_TOKEN needed.
API_KEY=change-me-before-deployment

# ── App URL ────────────────────────────────────────────────────────────────
# Public base URL of your HiveRunr instance — used in email links.
# No trailing slash.
APP_URL=http://localhost

# Default timezone used in the scheduler UI and for cron schedule display.
# Must be a valid IANA timezone name (e.g. Europe/London, America/New_York).
# Defaults to UTC if not set.
APP_TIMEZONE=UTC

# ── AgentMail.to (email sending) ───────────────────────────────────────────
# Used for: flow failure/success alerts and owner password-reset emails.
# Sign up at https://agentmail.to, create an inbox, and copy your API key.
#
# AGENTMAIL_FROM must be a valid inbox address for your account, e.g.:
#   alerts@agentmail.to   (shared agentmail.to domain)
#   alerts@yourdomain.com (custom domain — requires domain verification)
AGENTMAIL_API_KEY=
AGENTMAIL_FROM=

# Owner email — receives a notification on every flow failure across all flows.
# Also used as the email address for the "Forgot password?" reset flow.
# Must match the email set on the owner account in HiveRunr.
OWNER_EMAIL=

# ── Integrations ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI — required for action.llm_call
OPENAI_API_KEY=

# Slack incoming webhook — used by action.slack nodes in flows
SLACK_WEBHOOK_URL=

# ── Webhook rate limiting ─────────────────────────────────────────────────
# Max webhook calls per endpoint per window. Set WEBHOOK_RATE_LIMIT=0 to disable.
WEBHOOK_RATE_LIMIT=60
WEBHOOK_RATE_WINDOW=60

# ── External secrets provider (optional) ─────────────────────────────────
# Leave SECRETS_PROVIDER unset to use env vars only (default).
# Values fetched from a provider are merged into env vars at startup.
# Existing env vars always take precedence (local .env overrides keep working).
SECRETS_PROVIDER=

# AWS Secrets Manager  (SECRETS_PROVIDER=aws)
# The secret must be a JSON object whose keys map to env var names, e.g.:
#   {"SECRET_KEY": "...", "DATABASE_URL": "...", "AGENTMAIL_API_KEY": "..."}
# Credentials are picked up automatically via IAM role, ~/.aws, or env vars.
# Requires: pip install boto3
AWS_SECRET_NAME=
AWS_REGION=us-east-1

# HashiCorp Vault KV v2  (SECRETS_PROVIDER=vault)
# Use either a static token OR AppRole (role_id + secret_id).
# No extra package needed — uses httpx which is already installed.
VAULT_ADDR=http://vault:8200
VAULT_SECRET_PATH=secret/data/hiverunr
VAULT_TOKEN=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── Run Script node ───────────────────────────────────────────────────────
# The "Run Python Script" (action.run_script) node executes arbitrary Python
# via exec() with os, json, and time available in scope.  It is DISABLED by
# default.  Only enable it if you fully trust every user who can edit flows —
# a malicious script could read env vars, write files, or make network calls.
# Every execution is written to the 'audit' logger at WARNING level.
ENABLE_RUN_SCRIPT=false
